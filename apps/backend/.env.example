# Backend Environment Configuration
# COPY this file to .env and update with your actual values
# NEVER commit .env to version control!

# ==============================================================================
# NODE ENVIRONMENT
# ==============================================================================
NODE_ENV=development
# Options: development, production, staging

# ==============================================================================
# PORT & SERVER CONFIGURATION
# ==============================================================================
PORT=5000
# The port the Express server will listen on

REQUEST_TIMEOUT_MS=30000
# Request timeout in milliseconds (prevents slow-read attacks)

# ==============================================================================
# DATABASE CONFIGURATION (SECURITY CRITICAL)
# ==============================================================================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
# MongoDB connection string
# NEVER use hardcoded credentials in production
# Use MongoDB connection string from a secure vault

# ==============================================================================
# JWT CONFIGURATION (SECURITY CRITICAL)
# ==============================================================================
JWT_ACCESS_SECRET=your-super-secret-jwt-access-key-min-32-chars-required
# Used to sign access tokens
# Requirements:
#   - Minimum 32 characters
#   - Use cryptographically secure random values
#   - Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   - CHANGE in production

JWT_REFRESH_SECRET=your-super-secret-jwt-refresh-key-min-32-chars-required
# Used to sign refresh tokens
# Requirements: Same as JWT_ACCESS_SECRET

JWT_ACCESS_EXPIRY=15m
# Access token expiration time (e.g., 15m, 1h)
# Shorter is more secure but requires frequent refresh

JWT_REFRESH_EXPIRY=7d
# Refresh token expiration time (e.g., 7d, 30d)

# ==============================================================================
# FRONTEND CONFIGURATION
# ==============================================================================
CLIENT_URL=http://localhost:5173
# Frontend URL for CORS whitelist
# Production: https://yourdomain.com
# Development: http://localhost:5173

# ==============================================================================
# RATE LIMITING CONFIGURATION
# ==============================================================================
RATE_LIMIT_WINDOW=1
# Rate limit window in minutes

RATE_LIMIT_MAX=1000
# Maximum requests per window
# Recommendations:
#   Development: 10000
#   Production: 1000 (adjust based on load)

# ==============================================================================
# EMAIL CONFIGURATION (Optional)
# ==============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
# For Gmail: Use app-specific password, not your main password
# For other providers: Use their SMTP credentials

# ==============================================================================
# FILE UPLOAD CONFIGURATION
# ==============================================================================
MAX_FILE_SIZE=10485760
# Maximum file upload size in bytes (10MB default)

ALLOWED_FILE_TYPES=.pdf,.doc,.docx,.jpg,.jpeg,.png,.mp3,.mp4
# Comma-separated list of allowed file extensions

UPLOAD_DIR=./uploads
# Directory for storing uploaded files

# ==============================================================================
# API KEYS (SECURITY CRITICAL)
# ==============================================================================
DEEPSEEK_API_KEY=your-deepseek-api-key
# For AI/ML features

# ==============================================================================
# PAYMENT CONFIGURATION (PCI-DSS Compliance)
# ==============================================================================
PAYMENT_GATEWAY=stripe
# Payment provider (stripe, paypal, etc.)

PAYMENT_API_KEY=sk_test_your_stripe_api_key
# API key from payment provider
# NEVER log or expose this

PAYMENT_WEBHOOK_SECRET=whsec_your_webhook_secret
# Webhook signing secret

# ==============================================================================
# THIRD-PARTY SERVICES
# ==============================================================================
PUSH_NOTIFICATION_PUBLIC_KEY=your-vapid-public-key
PUSH_NOTIFICATION_PRIVATE_KEY=your-vapid-private-key
# Web Push Notification keys

# ==============================================================================
# LOGGING & MONITORING
# ==============================================================================
LOG_LEVEL=info
# Options: debug, info, warn, error
# Production: warn or error

LOG_DIR=./logs
# Directory for storing log files

# ==============================================================================
# SECURITY HEADERS
# ==============================================================================
HTTPS_ONLY=false
# Set to true in production to enforce HTTPS

HSTS_MAX_AGE=31536000
# HSTS max-age in seconds (1 year default)

API_DEPRECATION_DATE=
# Set deprecation date if planning to retire API version
# Example: 2026-12-31

# ==============================================================================
# TENANT/ORGANIZATION CONFIGURATION
# ==============================================================================
DEFAULT_ORGANIZATION_SLUG=masjid-rahma
# Default organization identifier

# ==============================================================================
# SECURITY BEST PRACTICES REMINDERS
# ==============================================================================
# 1. NEVER share this file via email or messaging
# 2. NEVER commit .env to version control
# 3. Rotate secrets regularly (at least quarterly)
# 4. Use environment variables for ALL secrets
# 5. Different secrets for dev, staging, and production
# 6. Use a secret management system (AWS Secrets Manager, HashiCorp Vault, etc.)
# 7. Audit who has access to production secrets
# 8. Log and monitor access to sensitive endpoints
# 9. Implement IP whitelisting for admin endpoints
# 10. Enable MFA for production access
